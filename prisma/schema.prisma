generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(uuid())
  clerkUserId      String            @unique
  email            String            @unique
  name             String?
  imageUrl         String?
  industry         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  bio              String?
  experience       Int?
  skills           String[]
  assessments         Assessments[]
  coverLetter         CoverLetter[]
  resume              Resume?
  industryInsights    IndustryInsights?   @relation(fields: [industry], references: [industry])
  jobApplications     JobApplication[]
  resumeVersions      ResumeVersion[]
  practicedQuestions  PracticedQuestion[]
  notes               Note[]
  bookmarks           Bookmark[]
  goals               Goal[]
  agentRuns           AgentRun[]
  weeklyPlans         WeeklyAgentPlan[]
  pendingChanges      PendingChanges[]
}

model Assessments {
  id             String   @id @default(uuid())
  userId         String
  quizScore      Float
  category       String
  improvementTip String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  questions      Json
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Resume {
  id        String   @id @default(uuid())
  userId    String   @unique
  content   String
  atsScore  Float?
  Feedback  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model CoverLetter {
  id             String   @id @default(uuid())
  userId         String
  content        String
  jobDescription String?
  companyName    String
  jobTitle       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model IndustryInsights {
  id                String        @id @default(uuid())
  industry          String        @unique
  salaryRanges      Json[]
  growthRate        Float
  demandLevel       DemandLevel
  topSkills         String[]
  marketOutlook     MarketOutlook
  keyTrends         String[]
  recommendedSkills String[]
  lastUpdated       DateTime      @default(now())
  nextUpdate        DateTime
  users             User[]

  @@index([industry])
}

model JobApplication {
  id          String            @id @default(uuid())
  userId      String
  companyName String
  position    String
  status      ApplicationStatus @default(APPLIED)
  jobUrl      String?
  notes       String?
  appliedAt   DateTime          @default(now())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

enum ApplicationStatus {
  APPLIED
  INTERVIEWING
  OFFERED
  REJECTED
  WITHDRAWN
}

model ResumeVersion {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  tag       String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Question {
  id                 String              @id @default(uuid())
  role               String
  topic              String
  difficulty         String
  question           String
  answer             String?
  practicedQuestions PracticedQuestion[]

  @@index([role])
  @@index([topic])
}

model PracticedQuestion {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  question   Question @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId])
  @@index([userId])
}

model Note {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  jobTitle  String
  company   String
  jobUrl    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Goal {
  id          String   @id @default(uuid())
  userId      String
  title       String
  target      Int
  progress    Int      @default(0)
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum AgentRunStatus {
  PENDING
  PROCESSING
  PENDING_REVIEW
  COMPLETED
  FAILED
}

model AgentRun {
  id            String        @id @default(cuid())
  userId        String
  agentType     String
  status        AgentRunStatus @default(PENDING)
  inputSummary  String
  outputSummary String
  toolCallLog   Json
  durationMs    Int?
  metadata      Json?         // Additional agent-specific data
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id])

  @@index([userId, agentType])
  @@index([status])
}

model WeeklyAgentPlan {
  id              String   @id @default(cuid())
  userId          String
  weekOf          DateTime
  readinessScore  Int
  skillFocus      Json
  resumeTips      Json
  interviewFocus  String
  rawAgentOutput  String
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@unique([userId, weekOf])
}

model PendingChanges {
  id           String   @id @default(cuid())
  userId       String
  changes      Json
  metadata     Json
  status       PendingChangeStatus @default(pending)
  approvedBy   String?
  approvedAt   DateTime?
  rejectedAt   DateTime?
  rejectReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

enum PendingChangeStatus {
  pending
  approved
  rejected
  partially_approved
}

enum DemandLevel {
  High
  Medium
  Low
}

enum MarketOutlook {
  Positive
  Neutral
  Negative
}
